{
  "name": "ebrar-islami-website",
  "private": true,
  "description": "Ebrar Islami's Personal Website",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint ./src",
    "prettier:check": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\"",
    "format": "prettier . --write",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@heroicons/react": "2.2.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "sharp": "0.34.5",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.1.6",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "eslint": "10.0.3",
    "husky": "9.1.7",
    "lint-staged": "16.3.3",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "sass": "1.98.0",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "1.4.0"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "engines": {
    "node": "24.x"
  }
}
